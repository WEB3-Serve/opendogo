// ========== Web3核心功能 ==========
let web3, registry, registrar, controller;
const lastOwnerCache = new Map();

function initWeb3(rpcUrl) {
    try {
        web3 = new Web3(rpcUrl);
        registry = new web3.eth.Contract(CONFIG.ENS_ABI, CONFIG.ENS_REGISTRY);
        registrar = new web3.eth.Contract(CONFIG.REGISTRAR_ABI, CONFIG.BASE_REGISTRAR);
        controller = new web3.eth.Contract(CONFIG.CONTROLLER_ABI, CONFIG.CONTROLLER);
        return true;
    } catch (e) {
        console.error('Web3初始化失败:', e);
        return false;
    }
}

function getWeb3() { return web3; }
function getRegistry() { return registry; }
function getRegistrar() { return registrar; }
function getController() { return controller; }

function getTokenId(label) {
    try {
        return web3.utils.keccak256(label);
    } catch (e) {
        return null;
    }
}

async function getOwnerWithRetry(tokenId, maxRetries = 3) {
    for (let attempt = 0; attempt < maxRetries; attempt++) {
        try {
            const owner = await registrar.methods.ownerOf(tokenId).call();
            if (owner === '0x0000000000000000000000000000000000000000') {
                return '';
            }
            return owner;
        } catch (e) {
            if (attempt === maxRetries - 1) throw e;
            await new Promise(r => setTimeout(r, 1000 * (attempt + 1)));
        }
    }
    return '';
}

async function getLastOwner(tokenId) {
    if (lastOwnerCache.has(tokenId)) {
        return lastOwnerCache.get(tokenId);
    }

    try {
        const transferContract = new web3.eth.Contract(CONFIG.TRANSFER_ABI, CONFIG.ENS_NFT);
        
        const events = await transferContract.getPastEvents("Transfer", {
            filter: { tokenId: tokenId },
            fromBlock: CONFIG.FROM_BLOCK,
            toBlock: "latest"
        });

        if (events.length === 0) {
            lastOwnerCache.set(tokenId, '');
            return '';
        }

        for (let i = events.length - 1; i >= 0; i--) {
            const to = events[i].returnValues.to;
            if (to !== "0x0000000000000000000000000000000000000000") {
                lastOwnerCache.set(tokenId, to);
                return to;
            }
        }
        
        const lastFrom = events[events.length - 1].returnValues.from;
        if (lastFrom && lastFrom !== "0x0000000000000000000000000000000000000000") {
            lastOwnerCache.set(tokenId, lastFrom);
            return lastFrom;
        }
        
        lastOwnerCache.set(tokenId, '');
        return '';
    } catch (error) {
        console.error('获取最后持有者失败:', error);
        return '';
    }
}

function clearCache() {
    lastOwnerCache.clear();
}

// 暴露Web3相关函数
window.initWeb3 = initWeb3;
window.getWeb3 = getWeb3;
window.getRegistry = getRegistry;
window.getRegistrar = getRegistrar;
window.getController = getController;
window.getTokenId = getTokenId;
window.getOwnerWithRetry = getOwnerWithRetry;
window.getLastOwner = getLastOwner;
window.clearCache = clearCache;