// ========== UI交互核心 ==========
let filteredResults = [];
let currentPage = 1, pageSize = 50, totalPages = 1;

function switchLanguage(lang) {
    currentLang = lang;
    document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.lang === lang);
    });
    document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.dataset.i18n;
        if (translations[lang] && translations[lang][key]) {
            if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                el.placeholder = translations[lang][key];
            } else if (el.tagName === 'OPTION') {
                el.textContent = translations[lang][key];
            } else {
                el.textContent = translations[lang][key];
            }
        }
    });
    updateDomainsCount();
    
    const langName = lang === 'zh' ? '中文' : 'English';
    addLog(translations[lang].logLangSwitch.replace('{lang}', langName) + `, Timezone: ${getTimeZone()}`, 'info');
    localStorage.setItem('preferred-language', lang);
}

function addLog(msg, type = 'info') {
    const logContainer = document.getElementById('logContainer');
    if (!logContainer) return;
    const entry = document.createElement('div');
    entry.className = `log-entry ${type}`;
    entry.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
    logContainer.prepend(entry);
    while (logContainer.children.length > 50) {
        logContainer.removeChild(logContainer.lastChild);
    }
}

function formatDate(d) {
    if (!d) return '';
    const date = new Date(d);
    if (currentLang === 'en') {
        return date.toLocaleString('en-US', {
            year: 'numeric', month: '2-digit', day: '2-digit',
            hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true
        }).replace(',', '');
    } else {
        return date.getFullYear() + '-' +
            String(date.getMonth() + 1).padStart(2, '0') + '-' +
            String(date.getDate()).padStart(2, '0') + ' ' +
            String(date.getHours()).padStart(2, '0') + ':' +
            String(date.getMinutes()).padStart(2, '0') + ':' +
            String(date.getSeconds()).padStart(2, '0');
    }
}

function shortenAddress(addr) { 
    if (!addr || addr === '0x0000000000000000000000000000000000000000') return '';
    return addr.length > 10 ? addr.substring(0,6) + '...' + addr.substring(addr.length-4) : addr; 
}

function updateDomainsCount() { 
    const cnt = document.getElementById('domainsText').value.split('\n').filter(s => s.trim()).length;
    document.getElementById('domainsCount').innerHTML = cnt + ' ' + translations[currentLang].domainCount; 
}

function clearDomains() { 
    document.getElementById('domainsText').value = ''; 
    updateDomainsCount(); 
}

function validateDomains() { 
    const textarea = document.getElementById('domainsText');
    textarea.style.borderColor = 'var(--success-color)';
    setTimeout(() => {
        textarea.style.borderColor = '';
    }, 500);
}

function getTimeZone() {
    try {
        return Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
    } catch {
        return 'UTC';
    }
}

function applyFilters() {
    if (typeof queryResults === 'undefined' || !queryResults) return;
    
    const status = document.getElementById('filterStatus').value;
    const premium = document.getElementById('filterPremium').value;
    const expiry = document.getElementById('filterExpiry').value;
    const grace = document.getElementById('filterGrace').value;
    const sort = document.getElementById('filterSort').value;
    const search = document.getElementById('filterSearch').value.toLowerCase().trim();

    if (!queryResults || queryResults.length === 0) {
        filteredResults = [];
        updateTable();
        updateStatistics();
        return;
    }

    let filtered = (queryResults.filter(r => r) || []).filter(r => {
        if (status !== 'all' && status !== 'address_desc' && status !== 'address_asc') {
            if (status === 'registered' && r.注册状态 !== 'registered') return false;
            if (status === 'unregistered' && r.注册状态 !== 'unregistered') return false;
            if (status === 'premium' && r.注册状态 !== 'premium') return false;
            if (status === 'expired' && r.过期状态 !== 'expired') return false;
            if (status === 'error' && r.注册状态 !== 'error') return false;
        }
        
        if (premium !== 'all') {
            if ((premium === 'in_premium') !== (r.溢价状态 === 'in_premium')) return false;
        }
        
        if (expiry !== 'all' && r.过期天数 !== '') {
            const d = parseInt(r.过期天数);
            if (expiry === 'expiring' && (isNaN(d) || d > 90 || d < 0)) return false;
            if (expiry === 'expired' && (!isNaN(d) && d >= 0)) return false;
            if (expiry === 'valid' && (!isNaN(d) && d < 0)) return false;
        }
        
        if (grace !== 'all') {
            if ((grace === 'in_grace') !== (r.宽限状态 === 'in_grace')) return false;
        }
        
        if (search) {
            const domainMatch = r.域名.toLowerCase().includes(search);
            const addressMatch = r.所有者地址 && r.所有者地址.toLowerCase().includes(search);
            if (!domainMatch && !addressMatch) return false;
        }
        
        return true;
    });

    if (status === 'address_desc' || status === 'address_asc') {
        const withAddress = filtered.filter(item => item.所有者地址);
        const withoutAddress = filtered.filter(item => !item.所有者地址);
        
        const addressGroups = new Map();
        withAddress.forEach(item => {
            const addr = item.所有者地址;
            if (!addressGroups.has(addr)) {
                addressGroups.set(addr, []);
            }
            addressGroups.get(addr).push(item);
        });
        
        const sortedGroups = Array.from(addressGroups.entries());
        sortedGroups.sort((a, b) => {
            return status === 'address_desc' 
                ? b[1].length - a[1].length
                : a[1].length - b[1].length;
        });
        
        const interleaved = [];
        const maxGroupSize = Math.max(...sortedGroups.map(g => g[1].length), 0);
        
        for (let i = 0; i < maxGroupSize; i++) {
            for (const [_, group] of sortedGroups) {
                if (i < group.length) {
                    interleaved.push(group[i]);
                }
            }
        }
        
        filtered = [...interleaved, ...withoutAddress];
    }
    else if (sort === 'expiry_asc') {
        filtered.sort((a, b) => {
            const aTime = a.时间戳 || 0;
            const bTime = b.时间戳 || 0;
            return aTime - bTime;
        });
    } else if (sort === 'expiry_desc') {
        filtered.sort((a, b) => {
            const aTime = a.时间戳 || 0;
            const bTime = b.时间戳 || 0;
            return bTime - aTime;
        });
    } else {
        filtered.sort((a, b) => (a.序号 || 0) - (b.序号 || 0));
    }

    filteredResults = filtered;
    currentPage = 1;
    updateTable();
    updateStatistics();
}

function updateTable() {
    if (!filteredResults || filteredResults.length === 0) {
        const noDataText = currentLang === 'zh' ? '暂无数据' : 'No data';
        document.getElementById('resultsBody').innerHTML = `<tr><td colspan="9" style="text-align: center;">${noDataText}</td></tr>`;
        document.getElementById('resultsCount').innerText = '(0)';
        updatePagination();
        return;
    }
    
    const tbody = document.getElementById('resultsBody');
    tbody.innerHTML = '';
    
    const addressCountMap = new Map();
    if (typeof queryResults !== 'undefined' && queryResults) {
        queryResults.filter(r => r && r.所有者地址).forEach(r => {
            const addr = r.所有者地址;
            if (addr) {
                addressCountMap.set(addr, (addressCountMap.get(addr) || 0) + 1);
            }
        });
    }
    
    pageSize = parseInt(document.getElementById('pageSize').value) || 50;
    totalPages = Math.ceil(filteredResults.length / pageSize) || 1;
    
    if (currentPage > totalPages) currentPage = totalPages || 1;
    
    const start = (currentPage-1) * pageSize;
    const end = Math.min(start + pageSize, filteredResults.length);
    
    const currentSearch = document.getElementById('filterSearch').value.toLowerCase().trim();
    
    for (let i=start; i<end; i++) {
        const r = filteredResults[i];
        
        let statusHtml = '';
        
        if (r.注册状态 === 'registered') {
            statusHtml = `<span style="color: var(--success-color);">${translations[currentLang].statusRegistered}</span>`;
        } else if (r.注册状态 === 'unregistered') {
            statusHtml = `<span style="color: var(--info-color);">${translations[currentLang].statusUnregistered}</span>`;
        } else if (r.注册状态 === 'premium') {
            statusHtml = `<span style="color: var(--warning-color);">${translations[currentLang].statusPremium}</span>`;
        } else if (r.过期状态 === 'expired') {
            statusHtml = `<span style="color: var(--danger-color);">${translations[currentLang].statusExpired}</span>`;
        } else {
            statusHtml = `
                <span style="color: var(--danger-color); display: flex; align-items: center; gap: 4px; justify-content: center;">
                    ${translations[currentLang].statusError}
                    <i class="fas fa-redo-alt retry-icon" 
                       style="cursor: pointer; font-size: 0.8rem; color: var(--warning-color);" 
                       onclick="retrySingleDomain('${r.域名}', ${r.序号-1}, event)"
                       title="${translations[currentLang].retrySingle}"></i>
                </span>
            `;
        }
        
        let addressHtml = '-';
        if (r.所有者地址) {
            const count = addressCountMap.get(r.所有者地址) || 1;
            const shortAddr = shortenAddress(r.所有者地址);
            const titleText = translations[currentLang].addressCount.replace('{count}', count);
            
            const isAddressInSearch = currentSearch && r.所有者地址 && 
                                     r.所有者地址.toLowerCase().includes(currentSearch);
            
            let addressContent = `
                <span class="address-text ${isAddressInSearch ? 'address-highlight' : ''}" 
                      onclick="filterByAddress('${r.所有者地址}')">${shortAddr}</span>
            `;
            
            if (count > 1) {
                addressContent += `
                    <span class="address-count" onclick="filterByAddress('${r.所有者地址}')">${count}</span>
                `;
            }
            
            if (count > 1) {
                addressContent += `
                    <i class="fas fa-times-circle address-clear" 
                       onclick="clearAddressSearch(event, '${r.所有者地址}')" 
                       title="${translations[currentLang].clearAddressSearch}"></i>
                `;
            }
            
            addressHtml = `
                <div class="address-wrapper" title="${titleText}">
                    <span class="short-address">
                        ${addressContent}
                    </span>
                </div>
            `;
        }
        
        const viewLink = `<a href="https://app.ens.domains/${r.域名}" target="_blank" class="view-link">${translations[currentLang].tableView}</a>`;
        
        tbody.innerHTML += `<tr>
            <td>${r.序号}</td>
            <td>${r.域名}</td>
            <td>${statusHtml}</td>
            <td>${r.过期天数 !== undefined && r.过期天数 !== '' ? r.过期天数 : '-'}</td>
            <td>${r.过期时间 || '-'}</td>
            <td>${r.宽限期结束 || '-'}</td>
            <td>${r.注册时间 || '-'}</td>
            <td>${addressHtml}</td>
            <td>${viewLink}</td>
        </tr>`;
    }
    
    document.getElementById('resultsCount').innerText = `(${filteredResults.length})`;
    updatePagination();
    
    const tableContainer = document.querySelector('.results-table-container');
    if (tableContainer) {
        tableContainer.scrollTop = 0;
    }
}

function updatePagination() {
    document.getElementById('pageInfo').innerHTML = `${translations[currentLang].page} ${currentPage} ${translations[currentLang].pageOf} ${totalPages} ${translations[currentLang].pageTotal}`;
    document.getElementById('pageInput').value = currentPage;
    const btns = document.querySelectorAll('#pagination .page-btn');
    if (btns.length >= 4) {
        btns[0].disabled = currentPage === 1;
        btns[1].disabled = currentPage === 1;
        btns[2].disabled = currentPage === totalPages || totalPages === 0;
        btns[3].disabled = currentPage === totalPages || totalPages === 0;
    }
}

function changePage(p) { 
    if(p >= 1 && p <= totalPages) { 
        currentPage = p; 
        updateTable(); 
    } 
}

function prevPage() { changePage(currentPage - 1); }
function nextPage() { changePage(currentPage + 1); }

function goToPage(v) { 
    let p = parseInt(v); 
    if(p >= 1 && p <= totalPages) changePage(p); 
    else document.getElementById('pageInput').value = currentPage; 
}

function changePageSize() { 
    pageSize = parseInt(document.getElementById('pageSize').value); 
    currentPage = 1; 
    updateTable(); 
}

function updateStatistics() {
    const list = filteredResults.length ? filteredResults : (typeof queryResults !== 'undefined' ? queryResults.filter(r=>r) : []);
    let reg = 0, unreg = 0, premium = 0, err = 0, exp = 0;
    
    list.forEach(r => {
        if (r) {
            if (r.注册状态 === 'registered') reg++;
            else if (r.注册状态 === 'unregistered') unreg++;
            else if (r.注册状态 === 'premium') premium++;
            else if (r.注册状态 === 'error') err++;
            if (r.过期状态 === 'expired') exp++;
        }
    });
    
    document.getElementById('statRegistered').innerText = reg;
    document.getElementById('statUnregistered').innerText = unreg;
    document.getElementById('statPremium').innerText = premium;
    document.getElementById('statErrors').innerText = err;
    document.getElementById('statExpired').innerText = exp;
    
    if (typeof updateRetryAllButton === 'function') {
        updateRetryAllButton();
    }
}

function filterByAddress(address) {
    const searchInput = document.getElementById('filterSearch');
    const currentSearch = searchInput.value.toLowerCase().trim();
    const addressLower = address.toLowerCase();
    
    if (currentSearch === addressLower) {
        searchInput.value = '';
    } else {
        searchInput.value = address;
    }
    
    applyFilters();
    
    const shortAddr = shortenAddress(address);
    addLog(translations[currentLang].logFilterByAddress.replace('{address}', shortAddr), 'info');
}

function filterByStat(status) {
    document.getElementById('filterStatus').value = status;
    applyFilters();
    
    const statusMap = {
        'registered': currentLang === 'zh' ? '已注册' : 'Registered',
        'unregistered': currentLang === 'zh' ? '未注册' : 'Unregistered',
        'premium': currentLang === 'zh' ? '溢价期' : 'Premium',
        'expired': currentLang === 'zh' ? '已过期' : 'Expired',
        'error': currentLang === 'zh' ? '错误' : 'Error'
    };
    addLog(currentLang === 'zh' ? `筛选状态: ${statusMap[status]}` : `Filter by status: ${statusMap[status]}`, 'info');
}

function clearFilters() {
    document.getElementById('filterStatus').value = 'all';
    document.getElementById('filterPremium').value = 'all';
    document.getElementById('filterExpiry').value = 'all';
    document.getElementById('filterGrace').value = 'all';
    document.getElementById('filterSort').value = 'default';
    document.getElementById('filterSearch').value = '';
    
    if (typeof queryResults !== 'undefined') {
        filteredResults = (queryResults.filter(r=>r) || []).sort((a,b)=>a.序号-b.序号);
    }
    currentPage = 1;
    updateTable();
    updateStatistics();
}

function clearAddressSearch(event, address) {
    event.stopPropagation();
    
    document.getElementById('filterSearch').value = '';
    applyFilters();
    
    const shortAddr = shortenAddress(address);
    addLog(currentLang === 'zh' ? `已清除地址 "${shortAddr}" 的搜索` : `Cleared address "${shortAddr}" search`, 'info');
}

function exportToCSV() {
    const data = filteredResults.length ? filteredResults : (typeof queryResults !== 'undefined' ? queryResults.filter(r => r).sort((a,b) => a.序号 - b.序号) : []);
    if (!data.length) return;
    
    const cols = [
        translations[currentLang].tableNo,
        translations[currentLang].tableDomain,
        translations[currentLang].tableStatus,
        translations[currentLang].tableExpiryDays,
        translations[currentLang].tableExpiryTime,
        translations[currentLang].tableGraceEnd,
        translations[currentLang].tableRegTime,
        translations[currentLang].tableOwner,
        translations[currentLang].tableAction
    ];
    
    let csv = cols.join(',') + '\n';
    
    data.forEach(r => {
        let statusDisplay = '';
        if (r.注册状态 === 'registered') statusDisplay = translations[currentLang].statusRegistered;
        else if (r.注册状态 === 'unregistered') statusDisplay = translations[currentLang].statusUnregistered;
        else if (r.注册状态 === 'premium') statusDisplay = translations[currentLang].statusPremium;
        else if (r.过期状态 === 'expired') statusDisplay = translations[currentLang].statusExpired;
        else statusDisplay = translations[currentLang].statusError;
        
        const escapeCSV = (str) => {
            if (!str) return '';
            str = str.toString();
            if (str.includes(',') || str.includes('"') || str.includes('\n')) {
                return '"' + str.replace(/"/g, '""') + '"';
            }
            return str;
        };
        
        csv += [
            escapeCSV(r.序号),
            escapeCSV(r.域名),
            escapeCSV(statusDisplay),
            escapeCSV(r.过期天数 || ''),
            escapeCSV(r.过期时间 || ''),
            escapeCSV(r.宽限期结束 || ''),
            escapeCSV(r.注册时间 || ''),
            escapeCSV(r.所有者地址 || ''),
            escapeCSV(`https://app.ens.domains/${r.域名}`)
        ].join(',') + '\n';
    });
    
    const blob = new Blob(['\uFEFF' + csv], {type:'text/csv;charset=utf-8;'});
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    
    const now = new Date();
    const year = now.getFullYear();
    const month = String(now.getMonth() + 1).padStart(2, '0');
    const day = String(now.getDate()).padStart(2, '0');
    const hours = String(now.getHours()).padStart(2, '0');
    const minutes = String(now.getMinutes()).padStart(2, '0');
    const seconds = String(now.getSeconds()).padStart(2, '0');
    
    const timestamp = `${year}-${month}-${day}-${hours}${minutes}${seconds}`;
    const langSuffix = currentLang === 'zh' ? 'zh' : 'en';
    
    link.download = `ens_${timestamp}_${langSuffix}.csv`;
    link.click();
    
    addLog(translations[currentLang].logExport.replace('{count}', data.length), 'success');
}

