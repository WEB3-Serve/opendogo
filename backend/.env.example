# ===== Core =====
PORT=3000
JWT_SECRET=replace-with-strong-random-string

# ===== Admin Login (fallback when Supabase vars are empty) =====
ADMIN_ACCOUNT=admin
ADMIN_PASSWORD=ChangeThisPassword!

# Google Authenticator Base32 密钥（示例）
# 生产请替换为你自己的密钥
ADMIN_2FA=JBSWY3DPEHPK3PXP

# ===== Supabase Auth (推荐，支持邮箱验证) =====
# 配置后，/api/admin/auth/prelogin 会使用 Supabase 邮箱+密码登录
# 且要求 email_confirmed_at 已存在（即邮箱已验证）
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ===== Database =====
# 免费数据库建议：Supabase Postgres 或 Neon PostgreSQL
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# ===== CORS =====
# Vercel 同域部署可直接使用 *，也可以指定域名
CORS_ORIGIN=*
