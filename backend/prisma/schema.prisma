generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum CardType {
  DAY
  WEEK
  MONTH
  SEASON
  YEAR
  FOREVER
}

enum ConfigType {
  BASIC
  SECURITY
  API
}

model UserGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(80)
  description String?  @db.VarChar(255)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            BigInt                 @id @default(autoincrement())
  walletAddress String                 @unique @db.VarChar(120)
  nickname      String?                @db.VarChar(80)
  email         String?                @db.VarChar(120)
  isActive      Boolean                @default(true)
  groupId       Int?
  group         UserGroup?             @relation(fields: [groupId], references: [id])
  activations   UserActivationRecord[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model UserActivationRecord {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt
  cardKeyId    BigInt?
  activatedAt  DateTime @default(now())
  expiredAt    DateTime?
  sourceIp     String?  @db.VarChar(60)
  userAgent    String?  @db.VarChar(255)
  transactionId String? @db.VarChar(80)

  user    User    @relation(fields: [userId], references: [id])
  cardKey CardKey? @relation(fields: [cardKeyId], references: [id])

  @@index([userId, activatedAt])
}

model CardGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(80)
  description String?  @db.VarChar(255)
  cardRules   CardRule[]
  cardKeys    CardKey[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CardRule {
  id          BigInt    @id @default(autoincrement())
  name        String    @db.VarChar(80)
  type        CardType
  amount      Int       @default(1)
  groupId     Int?
  group       CardGroup? @relation(fields: [groupId], references: [id])
  prefix      String?   @db.VarChar(20)
  length      Int       @default(16)
  isEnabled   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CardKey {
  id           BigInt    @id @default(autoincrement())
  code         String    @unique @db.VarChar(64)
  type         CardType
  groupId       Int?
  group        CardGroup? @relation(fields: [groupId], references: [id])
  isUsed       Boolean   @default(false)
  usedByUserId BigInt?
  usedAt       DateTime?
  expiredAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activations  UserActivationRecord[]

  @@index([groupId, isUsed])
}

model WebsiteConfig {
  id         Int      @id @default(autoincrement())
  siteName   String   @db.VarChar(120)
  logoUrl    String?  @db.VarChar(255)
  icpNo      String?  @db.VarChar(80)
  contactEmail String? @db.VarChar(120)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EnsQueryConfig {
  id               Int      @id @default(autoincrement())
  rpcEndpoint      String   @db.VarChar(255)
  timeoutMs        Int      @default(15000)
  retryCount       Int      @default(2)
  cacheSeconds     Int      @default(30)
  parallelRequests Int      @default(30)
  isEnabled        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Notice {
  id         BigInt   @id @default(autoincrement())
  title      String   @db.VarChar(120)
  content    String   @db.Text
  isPinned   Boolean  @default(false)
  isPublished Boolean @default(false)
  publishedAt DateTime?
  createdBy  String?  @db.VarChar(80)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SystemConfig {
  id         BigInt      @id @default(autoincrement())
  configType ConfigType
  configKey  String      @db.VarChar(80)
  configJson Json
  version    Int
  isActive   Boolean     @default(true)
  remark     String?     @db.VarChar(255)
  createdBy  String?     @db.VarChar(80)
  createdAt  DateTime    @default(now())

  @@index([configType, configKey, isActive])
  @@unique([configType, configKey, version])
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  operator    String   @db.VarChar(80)
  action      String   @db.VarChar(120)
  module      String   @db.VarChar(60)
  targetId    String?  @db.VarChar(80)
  requestIp   String?  @db.VarChar(60)
  detail      Json?
  createdAt   DateTime @default(now())

  @@index([module, createdAt])
}
